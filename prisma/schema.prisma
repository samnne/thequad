generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  lid         String   @id @default(uuid()) @db.Uuid
  title       String
  description String
  price       Int
  hidden      Boolean  @default(false)
  imageUrls   String[]
  sellerId    String?  @db.Uuid
  createdAt   DateTime @default(now())
  archived    Boolean  @default(false)
  sold        Boolean  @default(false)
  latitude    Float?
  longitude   Float?
  views       Int      @default(0)
  condition   String?
  category    String?

  likes         Like[]
  conversations Conversation[]
  seller        User?          @relation(fields: [sellerId], references: [uid], onDelete: SetNull)
}

model Like {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  listingId String?  @db.Uuid
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [uid], onDelete: SetNull)
  listing Listing? @relation(fields: [listingId], references: [lid], onDelete: SetNull)

  @@unique([userId, listingId])
}

model UserPreferences {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  defaultCategory  String?
  defaultCondition String?
  defaultLocation  String?
  defaultLat       Float?
  defaultLng       Float?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [uid], onDelete: Cascade)
}

model Review {
  rid        String     @id @default(uuid()) @db.Uuid
  rating     Int
  comment    String?
  role       ReviewRole
  reviewerId String?    @db.Uuid
  revieweeId String?    @db.Uuid
  createdAt  DateTime   @default(now())
  reviewee   User?      @relation("ReviewsReceived", fields: [revieweeId], references: [uid], onDelete: SetNull)
  reviewer   User?      @relation("ReviewsGiven", fields: [reviewerId], references: [uid], onDelete: SetNull)

  @@unique([reviewerId, revieweeId, role])
}

model User {
  uid                   String           @id @db.Uuid
  email                 String           @unique
  name                  String
  username              String?          @unique
  profileURL            String
  isVerified            Boolean          @default(false)
  createdAt             DateTime         @default(now())
  rating                Float            @default(0)
  hidden                Boolean          @default(false)
  buyerConversations    Conversation[]   @relation("ConversationBuyer")
  sellerConversations   Conversation[]   @relation("ConversationSeller")
  listings              Listing[]
  messages              Message[]
  likes                 Like[]
  reportsFiled          Report[]         @relation("ReportsFiled")
  reportsReceived       Report[]         @relation("ReportsReceived")
  reviewsReceived       Review[]         @relation("ReviewsReceived")
  reviewsGiven          Review[]         @relation("ReviewsGiven")
  preferences           UserPreferences?
  pushToken             PushToken?
  faculty               String?
  year                  Int?
  intent                String?
  bio                   String?
  category_interests    String[]
  campus_area           String?
  reports_made          String[]         @db.Uuid // Carry the unique ID of whatever a user reported (e.g., listing ID, user ID, etc.)
  enabled_notifications Boolean          @default(false)
  onboarding_completed  Boolean          @default(false)
 
  accepted_eula         Boolean          @default(false)
  Blocker               BlockedUser[]    @relation("Blocker")
  Blocked               BlockedUser[]    @relation("Blocked")
}

model BlockedUser {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [uid], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [uid], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Conversation {
  cid       String    @id @default(uuid()) @db.Uuid
  listingId String?   @db.Uuid
  buyerId   String?   @db.Uuid
  createdAt DateTime  @default(now())
  sellerId  String?   @db.Uuid
  updatedAt DateTime  @updatedAt
  buyer     User?     @relation("ConversationBuyer", fields: [buyerId], references: [uid], onDelete: SetNull)
  listing   Listing?  @relation(fields: [listingId], references: [lid], onDelete: SetNull)
  seller    User?     @relation("ConversationSeller", fields: [sellerId], references: [uid], onDelete: SetNull)
  messages  Message[]

  @@unique([listingId, buyerId])
}

model Message {
  mid            String       @id @default(uuid()) @db.Uuid
  text           String
  edited         Boolean      @default(false)
  conversationId String       @db.Uuid
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  senderId       String?      @db.Uuid
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [cid], onDelete: Cascade)
  sender         User?        @relation(fields: [senderId], references: [uid], onDelete: SetNull)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WaitlistTable {
  id            BigInt   @id @default(autoincrement())
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  full_name     String
  uvic_email    String
  intent        String
  referral_code String?
  referred_by   String?
}

model PushToken {
  id        String   @id @default(cuid())
  token     String
  platform  String?
  updatedAt DateTime @updatedAt
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@map("push_tokens")
}

model Report {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  reason         ReportReason
  description    String?
  status         ReportStatus @default(PENDING)
  adminNote      String?
  autoHidden     Boolean      @default(false)
  resolvedAt     DateTime?
  itemReported   String?
  itemReportedId String?      @db.Uuid

  resolvedById String? @db.Uuid

  reporterId   String? @db.Uuid // ← make nullable
  targetUserId String? @db.Uuid // ← make nullable
  reporter     User?   @relation("ReportsFiled", fields: [reporterId], references: [uid], onDelete: SetNull)
  targetUser   User?   @relation("ReportsReceived", fields: [targetUserId], references: [uid], onDelete: SetNull)

  @@index([targetUserId])
  @@index([reporterId])
  @@index([status])
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportReason {
  SPAM
  FAKE_LISTING
  HARASSMENT
  SCAM
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ReviewRole {
  BUYER
  SELLER
}
